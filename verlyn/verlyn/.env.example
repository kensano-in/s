# ============================================================
# VERLYN PLATFORM — Environment Variables
# Copy to .env.local and fill in values
# ============================================================

# ── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://verlyn:password@localhost:5432/verlyn_db"
MONGODB_URI="mongodb://localhost:27017/verlyn_messages"
REDIS_URL="redis://localhost:6379"

# ── Auth ────────────────────────────────────────────────────
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET="your-jwt-secret-here"

# ── Storage ─────────────────────────────────────────────────
S3_BUCKET_NAME="verlyn-media"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="ap-south-1"
CDN_URL="https://cdn.verlyn.in"

# ── WebSocket Gateway ───────────────────────────────────────
WS_GATEWAY_URL="ws://localhost:4000"

# ── AI Services ─────────────────────────────────────────────
OPENAI_API_KEY=""
OPENAI_MODERATION_ENABLED=true

# ── Platform ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_PLATFORM_NAME="Verlyn"
NEXT_PUBLIC_PLATFORM_DOMAIN="verlyn.in"
